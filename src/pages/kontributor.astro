---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="contributor-page">
    <a href="/" class="back-button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Kembali
    </a>
    
    <div class="content-wrapper">
      <div class="avatar-container">
        <div class="glow-ring"></div>
        <img 
          src="https://picsum.photos/seed/kontributor/400/400" 
          alt="Kontributor" 
          class="rotating-avatar"
        />
      </div>
      
      <div class="text-content">
        <h1 class="title">Kontributor</h1>
        <p class="subtitle">Placeholder untuk profil kontributor</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contributor-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, var(--bg-elevated) 0%, var(--bg-page) 100%);
    position: relative;
    overflow: hidden;
  }

  .back-button {
    position: absolute;
    top: 2rem;
    left: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: all var(--transition-normal);
    box-shadow: var(--shadow-sm);
    z-index: 10;
  }

  .back-button:hover {
    background: var(--bg-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    z-index: 1;
  }

  .avatar-container {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Decorative glowing ring behind the image */
  .glow-ring {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      var(--accent),
      var(--success),
      var(--warning),
      var(--danger),
      var(--accent)
    );
    filter: blur(20px);
    opacity: 0.6;
    animation: spin 8s linear infinite reverse;
  }

  .rotating-avatar {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 8px solid var(--bg-card);
    box-shadow: var(--shadow-lg), inset 0 0 20px rgba(0,0,0,0.5);
    animation: spin 15s linear infinite;
    z-index: 2;
  }

  .text-content {
    text-align: center;
    animation: fadeInUp 0.8s ease-out;
  }

  .title {
    font-size: 3rem;
    font-weight: 800;
    margin: 0;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin: 0.5rem 0 0 0;
    font-weight: 400;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .avatar-container {
      width: 240px;
      height: 240px;
    }
    .title {
      font-size: 2.25rem;
    }
    .back-button {
      top: 1rem;
      left: 1rem;
      padding: 0.5rem 1rem;
    }
  }
</style>
