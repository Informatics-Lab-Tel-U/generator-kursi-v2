---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: var(--bg-page); color: var(--text-primary); text-align: center; padding: 20px;">
        <div style="font-size: 120px; font-weight: 800; color: var(--accent); line-height: 1; text-shadow: 0 0 40px rgba(234, 179, 8, 0.2); margin-bottom: 24px;">
            404
        </div>
        
        <h1 style="font-size: 32px; font-weight: 700; margin: 0 0 16px 0; letter-spacing: -0.5px;">
            Halaman Tidak Ditemukan
        </h1>
        
        <p style="font-size: 16px; color: var(--text-muted); max-width: 400px; margin: 0 auto 40px auto; line-height: 1.6;">
            Maaf, halaman yang Anda cari mungkin telah dihapus, namanya diubah, atau sementara tidak tersedia.
        </p>

        <a href="/" style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center; background: var(--accent); color: #000; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; transition: all 0.2s ease; box-shadow: 0 4px 14px rgba(234, 179, 8, 0.3);">
            Kembali ke Beranda
        </a>
    </div>
</Layout>

<style>
    a:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(234, 179, 8, 0.4);
    }
</style>
