{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "generator-kursi-v2",
  "main": "./dist/server/entry.mjs",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  },
  "keep_vars": true
}