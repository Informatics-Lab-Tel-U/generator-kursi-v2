{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "generator-kursi",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }
}
